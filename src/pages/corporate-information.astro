---
import PageLayout from '../layouts/PageLayout.astro';
import PageHero from '../components/PageHero.astro';
import { site, legalNav } from '../data/site';
---

<PageLayout title="Corporate Information" description={`Corporate information and legal details for ${site.name}.`}>
  <PageHero title="Corporate Information" compact={true} />

  <section class="page-content">
    <div class="container prose">
      <h2>Company Details</h2>
      <p>
        <strong>Legal name:</strong> {site.name}<br />
        <strong>Registered office:</strong> {site.address}<br />
        <strong>General enquiries:</strong> <a href={`mailto:${site.email}`}>{site.email}</a><br />
        <strong>Telephone:</strong> {site.phone}
      </p>

      <h2>Business Description</h2>
      <p>
        A diversified holding company building long-term value across technology, property,
        health and wellness, agrifood, and workforce development sectors.
      </p>

      <h2>Legal &amp; Policy Documents</h2>
      <ul>
        {legalNav.map((item) => (
          <li><a href={item.href}>{item.label}</a></li>
        ))}
      </ul>
    </div>
  </section>
</PageLayout>
