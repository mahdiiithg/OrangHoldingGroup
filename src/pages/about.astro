---
import PageLayout from '../layouts/PageLayout.astro';
import PageHero from '../components/PageHero.astro';
---

<PageLayout
  title="About Us"
  description="Learn about Orang Holding Group's mission, operating model, and long-horizon portfolio stewardship approach."
>
  <PageHero
    eyebrow="About Us"
    title="A Disciplined Holding Structure for Long-Horizon Growth"
    description="Orang Holding Group provides active portfolio stewardship across essential and growth sectors with emphasis on governance, resilience, and compounding value."
  />

  <section class="page-content">
    <div class="container two-col">
      <div class="prose">
        <h2>Corporate Profile</h2>
        <p>
          Orang Holding Group is a diversified holding company anchored in Australia with
          a sector-led operating model across technology, property, health and wellness,
          agrifood, and workforce development.
        </p>
        <p>
          We prioritize long-term value creation over short-term optimization. Our parent
          company role is to allocate capital with discipline, maintain governance
          standards, and support operating platforms with capability and strategic
          direction.
        </p>

        <h2>Mission &amp; Principles</h2>
        <ul>
          <li>Build durable businesses in essential and growth industries</li>
          <li>Maintain transparent governance and accountability</li>
          <li>Invest in capability that compounds over time</li>
          <li>Expand selectively with operating readiness as the gate</li>
        </ul>

        <p><a href="/leadership-governance">Leadership &amp; Governance</a> · <a href="/markets">Markets</a></p>
      </div>

      <div class="card list-card">
        <h3>Group Structure</h3>
        <ul>
          <li>Parent holding company (corporate governance)</li>
          <li>Six sector operating platforms</li>
          <li>Three strategic portfolio groupings</li>
          <li>Centralized standards for finance and compliance</li>
        </ul>
      </div>
    </div>
  </section>
</PageLayout>
