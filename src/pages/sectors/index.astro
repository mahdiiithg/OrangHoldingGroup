---
import PageLayout from '../../layouts/PageLayout.astro';
import PageHero from '../../components/PageHero.astro';
import SectorCard from '../../components/SectorCard.astro';
import { sectors } from '../../data/sectors';
---

<PageLayout
  title="Our Sectors"
  description="Explore Orang Holding Group's operating fields across property operations, surety support, coastal operations, and automotive services."
>
  <PageHero
    eyebrow="Our Sectors"
    title="Our Operating Fields"
    description="Focused sectors built directly around our owned businesses and current investment priorities."
  />

  <section class="page-content">
    <div class="container">
      <div class="sector-grid">
        {sectors.map((sector) => (
          <SectorCard sector={sector} />
        ))}
      </div>

      <div class="logic-grid" style="margin-top: 2rem;">
        <article class="card logic-card">
          <h3>Property &amp; Infrastructure Operations</h3>
          <p>CPMS-led operational field for managed property performance and compliance.</p>
        </article>
        <article class="card logic-card">
          <h3>Risk, Surety &amp; Coastal Services</h3>
          <p>Orange Surety and Coast Plannet operating fields for reliable execution support.</p>
        </article>
        <article class="card logic-card">
          <h3>Automotive Services Growth Field</h3>
          <p>Tiptop Wash concept for scalable automotive cleaning and car services.</p>
        </article>
      </div>
    </div>
  </section>
</PageLayout>
