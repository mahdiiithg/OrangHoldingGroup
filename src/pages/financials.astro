---
import PageLayout from '../layouts/PageLayout.astro';
import PageHero from '../components/PageHero.astro';
---

<PageLayout
  title="Financials"
  description="Financial information and reporting for Orang Holding Group."
>
  <PageHero
    eyebrow="Financials"
    title="Financial Information"
    description="Key financial disclosures and reporting resources for stakeholders."
    compact={true}
  />

  <section class="page-content">
    <div class="container">
      <div class="financials-grid">
        <article class="card financials-card">
          <h3>Annual Report 2025</h3>
          <p>Comprehensive overview of group performance, portfolio developments, and outlook.</p>
          <a href="#">Download PDF (coming soon)</a>
        </article>
        <article class="card financials-card">
          <h3>Interim Update 2026</h3>
          <p>Half-year performance summary and sector highlights.</p>
          <a href="#">Download PDF (coming soon)</a>
        </article>
        <article class="card financials-card">
          <h3>Investor Presentation</h3>
          <p>Group strategy, portfolio logic, and market positioning overview.</p>
          <a href="#">Download PDF (coming soon)</a>
        </article>
        <article class="card financials-card">
          <h3>Financial Calendar</h3>
          <p>Reporting dates, AGM schedule, and key corporate events.</p>
          <a href="/corporate-events">View calendar</a>
        </article>
      </div>

      <div class="prose" style="margin-top: 2rem;">
        <p>
          Full financial document hosting and investor portal integration are planned for
          the next phase. For immediate enquiries, visit
          <a href="/investor-relations">Investor Relations</a>.
        </p>
      </div>
    </div>
  </section>
</PageLayout>
