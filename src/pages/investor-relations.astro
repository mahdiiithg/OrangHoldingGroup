---
import PageLayout from '../layouts/PageLayout.astro';
import PageHero from '../components/PageHero.astro';
import { site } from '../data/site';
---

<PageLayout
  title="Investor Relations"
  description="Investor relations information, disclosures, and contact details for Orang Holding Group."
>
  <PageHero
    eyebrow="Investor Relations"
    title="Information for Investors and Strategic Counterparties"
    description="Access group disclosures, financial information, and investor contact channels."
  />

  <section class="page-content">
    <div class="container">
      <div class="ir-grid">
        <article class="card ir-card">
          <h3>Financial Reports</h3>
          <p>Annual reports, interim updates, and key financial disclosures.</p>
          <a href="/financials">View financials</a>
        </article>
        <article class="card ir-card">
          <h3>Corporate Governance</h3>
          <p>Board structure, governance policies, and leadership information.</p>
          <a href="/leadership-governance">Governance</a>
        </article>
        <article class="card ir-card">
          <h3>Sustainability</h3>
          <p>ESG framework, reporting standards, and sustainability initiatives.</p>
          <a href="/sustainability">Sustainability</a>
        </article>
        <article class="card ir-card">
          <h3>News &amp; Announcements</h3>
          <p>Corporate updates, market views, and portfolio news.</p>
          <a href="/insights">News &amp; Insights</a>
        </article>
      </div>

      <div class="prose" style="margin-top: 2rem;">
        <h2>Investor Contact</h2>
        <p>
          For investor and media relations enquiries, contact
          <a href={`mailto:${site.investorEmail}`}>{site.investorEmail}</a> or use our
          <a href="/contact">contact form</a> and select Partnerships / Investment.
        </p>
        <h2>Email Alerts</h2>
        <p>
          Email alert signup for financial results and corporate announcements will be
          available in a future release. Contact us to register interest.
        </p>
      </div>
    </div>
  </section>
</PageLayout>
