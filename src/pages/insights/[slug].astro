---
import PageLayout from '../../layouts/PageLayout.astro';
import { insights, getInsight } from '../../data/insights';

export function getStaticPaths() {
  return insights.map((item) => ({ params: { slug: item.slug } }));
}

const { slug } = Astro.params;
const article = getInsight(slug!);

if (!article) {
  return Astro.redirect('/insights');
}

const paragraphs = article.body.split('\n\n').filter(Boolean);
---

<PageLayout title={article.title} description={article.excerpt}>
  <section class="page-content">
    <div class="container prose">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/">Home</a> / <a href="/insights">News &amp; Insights</a> / {article.title}
      </nav>

      <p class="meta-line">
        <span class="meta">{article.category}</span> ·
        <time datetime={article.publishDate}>
          {new Date(article.publishDate).toLocaleDateString('en-AU', {
            year: 'numeric',
            month: 'long',
            day: 'numeric',
          })}
        </time>
        · {article.author}
      </p>

      <h1>{article.title}</h1>

      {paragraphs.map((p) => (
        <p>{p}</p>
      ))}

      <p><a href="/insights">← Back to News &amp; Insights</a></p>
    </div>
  </section>
</PageLayout>
