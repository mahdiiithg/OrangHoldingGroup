---
import PageLayout from '../layouts/PageLayout.astro';
import HeroIntro from '../components/HeroIntro.astro';
import StockBar from '../components/StockBar.astro';
import InvestmentCarousel from '../components/InvestmentCarousel.astro';
import InvestmentLogoGrid from '../components/InvestmentLogoGrid.astro';
import NewsMagazine from '../components/NewsMagazine.astro';
import EventsSwiper from '../components/EventsSwiper.astro';
import { site } from '../data/site';
import { insights } from '../data/insights';
---

<PageLayout title={site.name} description={site.description}>
  <section class="hero hero-fp">
    <img
      class="hero-photo"
      src={site.heroImage}
      alt=""
      loading="eager"
      fetchpriority="high"
      decoding="async"
    />
    <div class="hero-overlay" aria-hidden="true"></div>
    <div class="container hero-fp-content">
      <h1>{site.heroTagline}</h1>
    </div>
  </section>

  <HeroIntro />
  <StockBar />
  <InvestmentCarousel />
  <InvestmentLogoGrid />
  <NewsMagazine items={insights} />
  <EventsSwiper />
</PageLayout>
