---
import { sectors } from '../data/sectors';
---

<section class="logo-grid-section" aria-label="Investment companies">
  <div class="container">
    <div class="logo-grid">
      {sectors.map((sector) => (
        <a href={`/sectors/${sector.slug}`} class="logo-grid-item" title={sector.name}>
          <span class="logo-grid-mark">{sector.logoLabel}</span>
          <span class="logo-grid-name">{sector.name}</span>
        </a>
      ))}
    </div>
  </div>
</section>
