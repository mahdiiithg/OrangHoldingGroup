---
import { stockMetrics } from '../data/site';
---

<div class="stock-bar" role="region" aria-label="Corporate highlights">
  <div class="container stock-bar-inner">
    {stockMetrics.map((item, i) => (
      <>
        {i > 0 && <span class="stock-divider" aria-hidden="true"></span>}
        <p>
          <strong>{item.label}:</strong> {item.value}
        </p>
      </>
    ))}
  </div>
</div>
