---
interface Props {
  eyebrow?: string;
  title: string;
  description?: string;
  compact?: boolean;
}

const { eyebrow, title, description, compact = false } = Astro.props;
---

<section class:list={['page-hero', compact && 'page-hero-compact']}>
  <div class="container">
    {eyebrow && <p class="eyebrow">{eyebrow}</p>}
    <h1>{title}</h1>
    {description && <p class="page-hero-desc">{description}</p>}
  </div>
</section>
