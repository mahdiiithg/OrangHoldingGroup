---
import { corporateEvents } from '../data/events';

interface Props {
  showHistoryLink?: boolean;
}

const { showHistoryLink = true } = Astro.props;
---

<section class="section section-events" id="events">
  <div class="events-inner">
    <h2 class="events-title">KEY CORPORATE EVENTS</h2>

    <div class="events-swiper" data-events-swiper>
      <button class="events-nav events-nav-left" type="button" aria-label="Previous events">
        <span aria-hidden="true">&lsaquo;</span>
      </button>

      <div class="events-viewport">
        <div class="events-axis" aria-hidden="true">
          <span class="events-axis-arrow events-axis-arrow-left"></span>
          <span class="events-axis-line"></span>
          <span class="events-axis-arrow events-axis-arrow-right"></span>
        </div>

        <div class="events-track" tabindex="0" aria-label="Corporate events timeline">
          {corporateEvents.map((event, index) => (
            <article class="events-slide" data-event-label={event.label} data-event-index={index}>
              <div class="event-top">
                {event.isLogo ? (
                  <div class="event-node event-node-logo" aria-hidden="true">
                    <span>OHG</span>
                  </div>
                ) : (
                  <div
                    class="event-node event-node-photo"
                    style={`background-image: url('${event.imageUrl}')`}
                    aria-hidden="true"
                  ></div>
                )}
                <div class="event-stem" aria-hidden="true"></div>
              </div>
              <div class="event-content">
                <h3>{event.title}</h3>
                <p>{event.summary}</p>
              </div>
            </article>
          ))}
        </div>
      </div>

      <button class="events-nav events-nav-right" type="button" aria-label="Next events">
        <span aria-hidden="true">&rsaquo;</span>
      </button>
    </div>

    <div class="events-options" aria-label="Jump to event period">
      {corporateEvents.map((event, index) => (
        <button
          type="button"
          class:list={['events-chip', index === 0 && 'is-active']}
          data-event-index={index}
        >
          {event.label}
        </button>
      ))}
    </div>

    {showHistoryLink && (
      <p class="events-cta">
        <a href="/corporate-events" class="events-history-link">View full corporate history</a>
      </p>
    )}
  </div>
</section>
