---
import { sectors } from '../data/sectors';
---

<section class="section section-investments" id="investments">
  <div class="container">
    <h2 class="investments-label">principal investments</h2>

    <div class="investment-carousel" data-investment-carousel>
      <div class="investment-slides">
        {sectors.map((sector, index) => (
          <article
            class:list={['investment-slide', index === 0 && 'is-active']}
            data-investment-index={index}
          >
            <div class="investment-slide-inner">
              <div class="investment-photo">
                <img
                  src={sector.imageUrl}
                  alt=""
                  loading={index === 0 ? 'eager' : 'lazy'}
                  width="560"
                  height="380"
                />
              </div>
              <div class="investment-copy">
                <h3>{sector.name.toUpperCase()}</h3>
                <p>{sector.summary}</p>
                <a href={`/sectors/${sector.slug}`} class="read-more">&gt; read more</a>
              </div>
            </div>
          </article>
        ))}
      </div>

      <div class="investment-carousel-footer">
        <span class="investment-counter" data-investment-counter>1 / {sectors.length}</span>
        <div class="investment-arrows">
          <button class="investment-arrow investment-arrow-left" type="button" aria-label="Previous investment">
            <span aria-hidden="true">&lsaquo;</span>
          </button>
          <button class="investment-arrow investment-arrow-right" type="button" aria-label="Next investment">
            <span aria-hidden="true">&rsaquo;</span>
          </button>
        </div>
      </div>
    </div>
  </div>
</section>
