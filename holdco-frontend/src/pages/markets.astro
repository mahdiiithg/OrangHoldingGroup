---
import PageLayout from '../layouts/PageLayout.astro';
import PageHero from '../components/PageHero.astro';
import { markets } from '../data/markets';
---

<PageLayout
  title="Markets"
  description="Orang Holding Group's operating base in Australia and staged Asia-Pacific and international growth outlook."
>
  <PageHero
    eyebrow="Markets"
    title="Australia Base, Regional and International Outlook"
    description="Market entry is guided by governance readiness, operating capability, and disciplined partnership evaluation."
  />

  <section class="page-content">
    <div class="container">
      <div class="sector-grid">
        {markets.map((market) => (
          <article class="card">
            <p class="meta">{market.status === 'active' ? 'Active' : 'Strategic'}</p>
            <h3>{market.name}</h3>
            <p>{market.summary}</p>
          </article>
        ))}
      </div>

      <div class="prose" style="margin-top: 2rem;">
        <h2>Growth Thesis</h2>
        <p>
          Expansion follows a staged model: capability assessment, local partnership evaluation,
          pilot operations, and full integration only after operating standards are validated.
          This approach protects brand credibility and portfolio performance.
        </p>
      </div>
    </div>
  </section>
</PageLayout>
