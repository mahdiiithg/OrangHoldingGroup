---
import PageLayout from '../../layouts/PageLayout.astro';
import PageHero from '../../components/PageHero.astro';
import SectorCard from '../../components/SectorCard.astro';
import { sectors } from '../../data/sectors';
---

<PageLayout
  title="Our Sectors"
  description="Explore Orang Holding Group's sector platforms across technology, property, health, agrifood, and workforce development."
>
  <PageHero
    eyebrow="Our Sectors"
    title="Sector-Led Portfolio Architecture"
    description="Each division is positioned as a long-term operating platform under one parent strategic framework."
  />

  <section class="page-content">
    <div class="container">
      <div class="sector-grid">
        {sectors.map((sector) => (
          <SectorCard sector={sector} />
        ))}
      </div>

      <div class="logic-grid" style="margin-top: 2rem;">
        <article class="card logic-card">
          <h3>Technology &amp; Capability</h3>
          <p>ICT Solutions and Training &amp; Development</p>
        </article>
        <article class="card logic-card">
          <h3>Essential Services</h3>
          <p>Property Management and Health, Wellness &amp; Beauty</p>
        </article>
        <article class="card logic-card">
          <h3>Food, Science &amp; Sustainability</h3>
          <p>AgriFood &amp; Nutrition</p>
        </article>
      </div>
    </div>
  </section>
</PageLayout>
