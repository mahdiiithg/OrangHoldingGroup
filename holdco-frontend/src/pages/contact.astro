---
import PageLayout from '../layouts/PageLayout.astro';
import PageHero from '../components/PageHero.astro';
import { site } from '../data/site';
import { sectors } from '../data/sectors';

const sectorParam = Astro.url.searchParams.get('sector');
const sectorOptions = sectors.map((s) => s.name);
---

<PageLayout
  title="Contact"
  description="Route your enquiry to the right division at Orang Holding Group."
>
  <PageHero
    eyebrow="Contact"
    title="Route Your Enquiry to the Right Division"
    description="Use the form to direct your enquiry to the relevant business function for faster, sector-specific response."
  />

  <section class="page-content">
    <div class="container two-col">
      <div class="prose">
        <h2>Contact Details</h2>
        <p>
          <strong>General enquiries:</strong><br />
          <a href={`mailto:${site.email}`}>{site.email}</a><br />
          {site.phone}
        </p>
        <p>
          <strong>Investor relations:</strong><br />
          <a href={`mailto:${site.investorEmail}`}>{site.investorEmail}</a>
        </p>
        <p>
          <strong>Media:</strong><br />
          <a href={`mailto:${site.mediaEmail}`}>{site.mediaEmail}</a>
        </p>
        <p><strong>Address:</strong><br />{site.address}</p>
      </div>

      <form class="card contact-form" action="#" method="post">
        <label>
          Full Name
          <input type="text" name="fullName" required />
        </label>
        <label>
          Work Email
          <input type="email" name="email" required />
        </label>
        <label>
          Enquiry Type
          <select name="enquiryType" required>
            <option value="">Select one</option>
            <option value="general" selected={!sectorParam || undefined}>General Corporate Enquiry</option>
            {sectors.map((s) => (
              <option value={s.slug} selected={sectorParam === s.slug || undefined}>{s.name}</option>
            ))}
            <option value="partnerships">Partnerships / Investment</option>
            <option value="media">Media / Other</option>
          </select>
        </label>
        <label>
          Message
          <textarea name="message" rows="4" required></textarea>
        </label>
        <button class="btn btn-primary" type="submit">Submit Enquiry</button>
        <p class="form-note">
          Form routing and anti-spam integration are planned for the next backend phase.
        </p>
      </form>
    </div>
  </section>
</PageLayout>
