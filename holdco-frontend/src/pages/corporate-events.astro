---
import PageLayout from '../layouts/PageLayout.astro';
import EventsSwiper from '../components/EventsSwiper.astro';
import { corporateEvents } from '../data/events';
---

<PageLayout
  title="Key Corporate Events"
  description="Institutional timeline of milestones in Orang Holding Group's development and portfolio evolution."
>
  <EventsSwiper showHistoryLink={false} />

  <section class="page-content">
    <div class="container">
      <h2>Full Timeline Archive</h2>
      <div class="events-full-list">
        {corporateEvents.map((event) => (
          <article class="card event-full-card">
            <div class="event-full-year">{event.label}</div>
            <div>
              <h3>{event.title}</h3>
              <p>{event.summary}</p>
              {event.tags && (
                <div class="event-tags">
                  {event.tags.map((tag) => (
                    <span class="event-tag">{tag}</span>
                  ))}
                </div>
              )}
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>
</PageLayout>
