---
import PageLayout from '../layouts/PageLayout.astro';
import PageHero from '../components/PageHero.astro';
---

<PageLayout
  title="Sustainability"
  description="ESG framework, sustainability reporting, and responsible business practices at Orang Holding Group."
>
  <PageHero
    eyebrow="Sustainability"
    title="Responsible Business Across the Portfolio"
    description="Consistent ESG standards and sustainability reporting across sector platforms."
  />

  <section class="page-content">
    <div class="container prose">
      <h2>Our Approach</h2>
      <p>
        Orang Holding Group integrates environmental, social, and governance considerations
        into portfolio oversight. Each sector platform reports against common group metrics
        with sector-specific supplements where relevant.
      </p>

      <h2>Focus Areas</h2>
      <ul>
        <li>Environmental performance and resource efficiency</li>
        <li>Workforce safety, development, and inclusion</li>
        <li>Governance transparency and ethical conduct</li>
        <li>Supply chain responsibility and traceability</li>
      </ul>

      <h2>Reporting</h2>
      <p>
        Our sustainability reporting framework aligns with recognized disclosure standards.
        Read our latest update in
        <a href="/insights/sustainability-reporting-framework">Group Sustainability Reporting Framework</a>.
      </p>
    </div>
  </section>
</PageLayout>
